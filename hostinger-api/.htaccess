# API Efficience Analytics
# Sécurité et configuration

# Empêcher l'accès direct au fichier config
<Files "config.php">
    Order Allow,Deny
    Deny from all
</Files>

# Headers de sécurité
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
</IfModule>

# Activer la réécriture si nécessaire
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Rediriger les erreurs 404 vers un JSON
    ErrorDocument 404 '{"error": "Not found", "message": "Endpoint non trouvé"}'
</IfModule>
